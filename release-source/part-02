 $index ] ) ) ? $meta[ $index ] : array();
            $result = self::import_image( $file_ref, 0, $image_meta, $index, $slug );
            $name = is_array( $file_ref ) ? sanitize_file_name( $file_ref['name'] ?? '' ) : '';

            if ( is_wp_error( $result ) ) {
                $results[] = array(
                    'index'         => $index,
                    'name'          => $name,
                    'ok'            => false,
                    'media_id'      => 0,
                    'url'           => '',
                    'error_code'    => $result->get_error_code(),
                    'error_message' => $result->get_error_message(),
                );
                continue;
            }

            $media_ids[] = $result;
            $results[] = array(
                'index'         => $index,
                'name'          => $name,
                'ok'            => true,
                'media_id'      => $result,
                'url'           => wp_get_attachment_url( $result ),
                'error_code'    => '',
                'error_message' => '',
            );
        }

        $response = array(
            'ok'                  => count( $media_ids ) === count( $files ),
            'received_file_count' => count( $files ),
            'successful_count'    => count( $media_ids ),
            'failed_count'        => count( $files ) - count( $media_ids ),
            'media_ids'           => $media_ids,
            'results'             => $results,
        );

        return new WP_REST_Response( $response, empty( $media_ids ) ? 422 : 200 );
    }

    public static function update_report( WP_REST_Request $request ) {
        $post_id = absint( $request['id'] );
        $post = get_post( $post_id );
        if ( ! $post || 'post' !== $post->post_type ) {
            return new WP_Error( 'yrs_post_not_found', '対象の記事が見つかりません。', array( 'status' => 404 ) );
        }

        $payload = $request->get_json_params();
        if ( ! is_array( $payload ) ) {
            return new WP_Error( 'yrs_invalid_json', 'JSON形式の本文が必要です。', array( 'status' => 400 ) );
        }

        $postarr = array( 'ID' => $post_id );
        if ( array_key_exists( 'title', $payload ) ) {
            $postarr['post_title'] = sanitize_text_field( $payload['title'] );
        }
        if ( array_key_exists( 'content', $payload ) ) {
            $postarr['post_content'] = wp_kses_post( $payload['content'] );
        }
        if ( array_key_exists( 'excerpt', $payload ) ) {
            $postarr['post_excerpt'] = sanitize_textarea_field( $payload['excerpt'] );
        }
        if ( ! empty( $payload['slug'] ) ) {
            $postarr['post_name'] = sanitize_title( $payload['slug'] );
        }

        if ( count( $postarr ) > 1 ) {
            $updated = wp_update_post( wp_slash( $postarr ), true );
            if ( is_wp_error( $updated ) ) {
                return $updated;
            }
        }

        if ( array_key_exists( 'seo_title', $payload ) ) {
            update_post_meta( $post_id, 'the_page_seo_title', sanitize_text_field( $payload['seo_title'] ) );
        }
        if ( array_key_exists( 'meta_description', $payload ) ) {
            update_post_meta( $post_id, 'the_page_meta_description', sanitize_textarea_field( $payload['meta_description'] ) );
        }
        if ( isset( $payload['media_ids'] ) && is_array( $payload['media_ids'] ) ) {
            $media_map = self::attach_existing_media( $post_id, $payload['media_ids'], $payload['featured_image_index'] ?? 0 );
            $updated_content = get_post_field( 'post_content', $post_id );
            foreach ( $media_map as $index => $media_id ) {
                $placeholder = '{{IMAGE_' . ( $index + 1 ) . '}}';
                if ( false !== strpos( $updated_content, $placeholder ) ) {
                    $updated_content = str_replace( $placeholder, self::build_image_figure( $media_id ), $updated_content );
                }
            }
            $updated_content = preg_replace( '/\{\{IMAGE_\d+\}\}/', '', $updated_content );
            wp_update_post( wp_slash( array( 'ID' => $post_id, 'post_content' => $updated_content ) ) );
        }

        return rest_ensure_response(
            array(
                'ok'          => true,
                'post_id'     => $post_id,
                'status'      => get_post_status( $post_id ),
                'edit_url'    => admin_url( 'post.php?post=' . $post_id . '&action=edit' ),
                'preview_url' => get_preview_post_link( $post_id ),
                'permalink'   => get_permalink( $post_id ),
            )
        );
    }

    public static function trash_report( WP_REST_Request $request ) {
        $post_id = absint( $request['id'] );
        $post = get_post( $post_id );
        if ( ! $post || 'post' !== $post->post_type ) {
            return new WP_Error( 'yrs_post_not_found', '対象の記事が見つかりません。', array( 'status' => 404 ) );
        }

        $trashed = wp_trash_post( $post_id );
        if ( ! $trashed ) {
            return new WP_Error( 'yrs_trash_failed', '記事をゴミ箱へ移動できませんでした。', array( 'status' => 500 ) );
        }

        return rest_ensure_response( array( 'ok' => true, 'post_id' => $post_id, 'status' => 'trash' ) );
    }

