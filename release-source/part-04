=> $image_results,
                'administrative_maps' => $administrative_maps,
                'edit_url'    => admin_url( 'post.php?post=' . $post_id . '&action=edit' ),
                'preview_url' => get_preview_post_link( $post_id ),
                'permalink'   => get_permalink( $post_id ),
            )
        );
    }

    private static function normalize_administrative_areas( $payload ) {
        $areas = array();

        if ( ! empty( $payload['administrative_areas'] ) && is_array( $payload['administrative_areas'] ) ) {
            $areas = $payload['administrative_areas'];
        } elseif ( ! empty( $payload['administrative_area'] ) ) {
            $areas = array( $payload['administrative_area'] );
        }

        $clean = array();
        foreach ( array_slice( $areas, 0, 3 ) as $area ) {
            $area = sanitize_text_field( $area );
            $area = preg_replace( '/[\x{3000}\s]+/u', '', $area );
            if ( '' !== $area && ! in_array( $area, $clean, true ) ) {
                $clean[] = $area;
            }
        }

        return $clean;
    }

