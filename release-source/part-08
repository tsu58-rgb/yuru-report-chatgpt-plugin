
add_action( 'save_post_post', function( $post_id, $post, $update ) {
    $has_report_title = false !== mb_strpos( (string) $post->post_title, '開催レポート' );
    $has_timewalk_meta = '' !== (string) get_post_meta( $post_id, '_yrs_timewalk_url', true );
    if ( wp_is_post_revision( $post_id ) || ( ! $has_report_title && ! $has_timewalk_meta ) ) {
        return;
    }
    $categories = wp_get_post_categories( $post_id );
    $categories[] = 1;
    $categories[] = 44;
    wp_set_post_categories( $post_id, array_values( array_unique( array_map( 'absint', $categories ) ) ), false );
}, 20, 3 );
