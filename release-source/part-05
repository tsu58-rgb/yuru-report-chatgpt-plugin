 => $area,
            'found'    => true,
            'media_id' => $best_id,
            'title'    => get_the_title( $best_id ),
            'url'      => $url,
            'message'  => 'メディアライブラリ内の既存画像を再利用します。',
        );
    }

    private static function normalize_map_text( $text ) {
        $text = rawurldecode( (string) $text );
        $text = preg_replace( '/\.(jpe?g|png|webp|gif)$/iu', '', $text );
        $text = preg_replace( '/[\x{3000}\s_\-・･（）()【】\[\]]+/u', '', $text );
        return mb_strtolower( $text, 'UTF-8' );
    }

    private static function insert_administrative_maps( $content, $map_results ) {
        $figures = array();
        foreach ( $map_results as $index => $result ) {
            $figure = '';
            if ( ! empty( $result['found'] ) && ! empty( $result['media_id'] ) ) {
                $figure = self::build_administrative_map_figure( absint( $result['media_id'] ), sanitize_text_field( $result['area'] ?? '' ) );
            }
            $figures[ $index ] = $figure;
            $numbered_placeholder = '{{ADMIN_MAP_' . ( $index + 1 ) . '}}';
            $content = str_replace( $numbered_placeholder, $figure, $content );
            if ( 0 === $index ) {
                $content = str_replace( '{{ADMIN_MAP}}', $figure, $content );
            }
        }

        // Remove unmatched placeholders so they never appear in the published article.
        $content = preg_replace( '/\{\{ADMIN_MAP(?:_\d+)?\}\}/', '', $content );

        // Fallback placement: if the GPT omitted the placeholder, place the first map immediately before the route section.
        if ( ! empty( $figures[0] ) && false === strpos( $content, 'yrs-administrative-map' ) ) {
            $patterns = array(
                '/<h2[^>]*>\s*今回歩いたルート\s*<\/h2>/u',
                '/<h2[^>]*>\s*今回の散歩ルート\s*<\/h2>/u',
                '/<h2[^>]*>\s*散歩ルート\s*<\/h2>/u',
                '/<h2[^>]*>\s*今回歩いた場所\s*<\/h2>/u',
                '/<h2[^>]*>\s*今回いくところ\s*<\/h2>/u',
            );
            $inserted = false;
            foreach ( $patterns as $pattern ) {
                if ( preg_match( $pattern, $content ) ) {
                    $content = preg_replace( $pattern, $figures[0] . "\n\n$0", $content, 1 );
                    $inserted = true;
                    break;
                }
            }
            if ( ! $inserted ) {
                $content = $figures[0] . "\n\n" . $content;
            }
        }

        return $content;
    }

    private static function build_administrative_map_figure( $media_id, $area ) {
        $src = wp_get_attachment_image_url( $media_id, 'full' );
        if ( ! $src ) {
            return '';
        }

        $alt = get_post_meta( $media_id, '_wp_attachment_image_alt', true );
        if ( '' === trim( (string) $alt ) ) {
            $alt = $area . 'の行政地図';
        }

        $caption = wp_get_attachment_caption( $media_id );
        $html  = '<figure class="wp-block-image size-full yrs-administrative-map">';
        $html .= '<img src="' . esc_url( $src ) . '" alt="' . esc_attr( $alt ) . '" class="wp-image-' . absint( $media_id ) . '">';
        if ( $caption ) {
            $html .= '<figcaption class="wp-element-caption">' . esc_html( $caption ) . '</figcaption>';
        }
        $html .= '</figure>';
        return $html;
    }

    private static function build_timewalk_block( $url ) {
