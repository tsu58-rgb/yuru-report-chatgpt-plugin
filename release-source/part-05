    }

    private static function set_tags( $post_id, $tags ) {
        if ( ! is_array( $tags ) ) {
            return;
        }
        $clean = array();
        foreach ( array_slice( $tags, 0, 20 ) as $tag ) {
            $tag = sanitize_text_field( $tag );
            if ( '' !== $tag ) {
                $clean[] = $tag;
            }
        }
        if ( ! empty( $clean ) ) {
            wp_set_post_tags( $post_id, $clean, false );
        }
    }

    private static function attach_existing_media( $post_id, $media_ids, $featured_index = 0 ) {
        $valid = array();
        foreach ( array_slice( (array) $media_ids, 0, self::MAX_FILES ) as $index => $media_id ) {
            $media_id = absint( $media_id );
            if ( ! $media_id || 'attachment' !== get_post_type( $media_id ) || 0 !== strpos( (string) get_post_mime_type( $media_id ), 'image/' ) ) {
                continue;
            }
            wp_update_post( array( 'ID' => $media_id, 'post_parent' => $post_id ) );
            $valid[ $index ] = $media_id;
        }
        $featured_index = absint( $featured_index );
        if ( isset( $valid[ $featured_index ] ) ) {
            set_post_thumbnail( $post_id, $valid[ $featured_index ] );
        } elseif ( ! empty( $valid ) ) {
            set_post_thumbnail( $post_id, reset( $valid ) );
        }
        return $valid;
    }

