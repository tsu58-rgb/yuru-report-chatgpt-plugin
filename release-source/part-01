    public static function authorize( WP_REST_Request $request ) {
        $settings = get_option( self::OPTION_KEY, array() );
        $stored   = (string) ( $settings['api_key'] ?? '' );
        if ( '' === $stored ) {
            return new WP_Error( 'yrs_no_api_key', 'APIキーが設定されていません。', array( 'status' => 503 ) );
        }

        $header = (string) $request->get_header( 'authorization' );
        if ( ! preg_match( '/^Bearer\s+(.+)$/i', $header, $matches ) ) {
            return new WP_Error( 'yrs_missing_auth', 'Bearer認証が必要です。', array( 'status' => 401 ) );
        }

        $provided = trim( $matches[1] );
        if ( ! hash_equals( $stored, $provided ) ) {
            return new WP_Error( 'yrs_bad_auth', 'APIキーが正しくありません。', array( 'status' => 403 ) );
        }

        return true;
    }

    public static function status() {
        $settings = get_option( self::OPTION_KEY, array() );
        $author   = get_user_by( 'id', absint( $settings['author_id'] ?? 0 ) );
        $category = get_term( absint( $settings['category_id'] ?? 0 ), 'category' );

        return rest_ensure_response(
            array(
                'ok'             => true,
                'plugin_version' => self::PLUGIN_VERSION,
                'registered_routes' => array( 'status', 'administrative-map', 'images/upload', 'create', 'posts/{id}' ),
                'site_name'      => get_bloginfo( 'name' ),
                'author'         => $author ? $author->display_name : '',
                'category'       => ( $category && ! is_wp_error( $category ) ) ? $category->name : '',
                'allow_publish'  => ! empty( $settings['allow_publish'] ),
                'max_images'     => self::MAX_FILES,
                'accepted_mimes' => array( 'image/jpeg', 'image/png', 'image/webp' ),
                'output_mime'    => 'image/webp',
                'filename_rule'  => 'post-slug-01.webp',
                'administrative_map_search' => true,
                'administrative_map_placeholder' => '{{ADMIN_MAP}}',
                'administrative_map_reuses_existing_media' => true,
                'separate_image_upload' => true,
                'post_update' => true,
                'post_trash' => true,
            )
        );
    }

    public static function administrative_map( WP_REST_Request $request ) {
        $area = sanitize_text_field( $request->get_param( 'administrative_area' ) );
        if ( '' === $area ) {
            return new WP_Error( 'yrs_missing_administrative_area', '行政区域名を指定してください。', array( 'status' => 400 ) );
        }

        $result = self::find_administrative_map( $area );
        return rest_ensure_response( $result );
    }

